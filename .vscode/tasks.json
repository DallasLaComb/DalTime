{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Build SAM",
      "type": "shell",
      "command": "sam build",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Backend: Start Local API",
      "type": "shell",
      "command": "sam local start-api --port 3000 --env-vars local/env.json --warm-containers EAGER --parameter-overrides LambdaArchitecture=x86_64",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Mounting.*$",
          "endsPattern": "^.*Running on http://127.0.0.1:3000.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "dependsOn": ["Backend: Build SAM", "DynamoDB Local: Create Tables"]
    },
    {
      "label": "Backend: Invoke Test Function",
      "type": "shell",
      "command": "sam local invoke TestFunction --no-event",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Backend: Validate SAM Template",
      "type": "shell",
      "command": "sam validate --template template.yaml",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Backend: Deploy to AWS",
      "type": "shell",
      "command": "sam deploy --guided",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Backend: Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Frontend: Start Dev Server",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Initial chunk files",
          "endsPattern": "Compiled successfully"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Install All Dependencies",
      "dependsOn": [
        "Backend: Install Dependencies",
        "Frontend: Install Dependencies"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "DynamoDB Local: Start",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}/backend/local"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOn": ["Docker: Ensure Running"]
    },
    {
      "label": "DynamoDB Local: Create Tables",
      "type": "shell",
      "command": "bash local/create-tables.sh",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOn": ["DynamoDB Local: Start"]
    },
    {
      "label": "DynamoDB Local: Stop",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}/backend/local"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Start Servers",
      "dependsOn": [
        "Backend: Start Local API",
        "Frontend: Start Dev Server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Start Full Stack (with install)",
      "dependsOn": [
        "Install All Dependencies",
        "DynamoDB Local: Create Tables",
        "Start Servers"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Start Full Stack",
      "dependsOn": [
        "DynamoDB Local: Create Tables",
        "Start Servers"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Docker: Ensure Running",
      "type": "shell",
      "command": "echo 'Unsupported OS for this task'",
      "linux": {
        "command": "if ! command -v docker &>/dev/null; then echo 'ERROR: Docker is not installed. Run: sudo apt install docker.io && sudo usermod -aG docker $USER'; exit 1; fi; if ! systemctl is-active --quiet docker 2>/dev/null; then echo 'Starting Docker daemon...'; sudo systemctl start docker; SECONDS=0; while ! systemctl is-active --quiet docker 2>/dev/null; do if [ $SECONDS -gt 60 ]; then echo 'ERROR: Docker failed to start within 60s'; exit 1; fi; echo \"  Waiting for Docker... (${SECONDS}s)\"; sleep 2; done; echo \"Docker is ready. (took ${SECONDS}s)\"; else echo 'Docker is already running.'; fi; if ! docker info >/dev/null 2>&1; then echo ''; echo 'WARNING: Docker is running but you cannot connect.'; echo 'You are likely not in the docker group. Run:'; echo '  sudo usermod -aG docker $USER'; echo 'Then log out and back in.'; exit 1; fi"
      },
      "windows": {
        "command": "try { docker info 2>$null | Out-Null; Write-Host 'Docker is already running.' } catch { Write-Host 'Starting Docker Desktop...'; Start-Process \"$env:ProgramFiles\\Docker\\Docker\\Docker Desktop.exe\"; $t=0; do { Start-Sleep 2; $t+=2; if($t -gt 120){Write-Host 'ERROR: Docker Desktop failed to start within 120s'; exit 1} } while (-not (docker info 2>$null)); Write-Host 'Docker is ready.' }",
        "options": {
          "shell": {
            "executable": "powershell",
            "args": ["-NoProfile", "-Command"]
          }
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Docker: List SAM Images",
      "type": "shell",
      "command": "docker images | grep -E 'REPOSITORY|lambda/nodejs' || echo 'No Lambda images found'",
      "windows": {
        "command": "docker images | findstr /R \"REPOSITORY lambda/nodejs\" || echo No Lambda images found"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Docker: Startup Blame",
      "type": "shell",
      "command": "echo '--- Docker systemd timing ---' && systemd-analyze blame 2>/dev/null | grep docker; echo ''; echo '--- Docker info ---' && docker info 2>&1 | grep -E 'Storage Driver|Server Version|Operating System|Total Memory'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Docker: Prune All",
      "type": "shell",
      "command": "echo 'Current disk usage:' && docker system df && echo '' && echo 'Pruning unused images, containers, networks, and build cache...' && docker system prune -a -f && echo '' && echo 'Disk usage after prune:' && docker system df",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
