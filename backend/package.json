{
  "name": "daltime-backend",
  "version": "1.0.0",
  "description": "DalTime scheduling application backend - AWS Lambda functions",
  "type": "module",
  "scripts": {
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "build": "PATH=\"$PATH:$(pwd)/node_modules/.bin\" sam build",
    "start": "PATH=\"$PATH:$(pwd)/node_modules/.bin\" sam local start-api --template template.yaml --port 3000",
    "deploy": "sam deploy --guided"
  },
  "keywords": [
    "aws",
    "lambda",
    "sam",
    "serverless"
  ],
  "author": "Dallas LaComb",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1024.0",
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/lib-dynamodb": "^3.995.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^25.3.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^7.0.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
